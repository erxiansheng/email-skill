# ─── 单邮箱模式（向后兼容）───
# 如果你只需要监控一个邮箱，可以只用 .env 配置。
# 如果需要监控多个邮箱，请使用 accounts.json（参考 accounts.json.example）。
# 当 accounts.json 存在时，.env 中的配置会被忽略。

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your@gmail.com
IMAP_PASS=your_app_password
IMAP_TLS=true
IMAP_MAILBOX=INBOX

# ─── 各邮箱密码说明 ───
# Gmail：需要应用专用密码 https://myaccount.google.com/apppasswords
# QQ 邮箱：IMAP_HOST=imap.qq.com，需要授权码
# 163 邮箱：IMAP_HOST=imap.163.com，需要授权码
# Outlook：IMAP_HOST=outlook.office365.com
